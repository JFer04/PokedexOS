---
import Layout from '../layouts/Layout.astro';
import PokemonCard from '../components/PokemonCard.astro';
import pokemonData from '../data/pokemon.json';

// Diccionario para el Dropdown en Español
const typeTranslations: any = {
  all: 'Todos los tipos',
  fire: 'Fuego', water: 'Agua', grass: 'Planta', electric: 'Eléctrico',
  ice: 'Hielo', fighting: 'Lucha', poison: 'Veneno', ground: 'Tierra',
  flying: 'Volador', psychic: 'Psíquico', bug: 'Bicho', rock: 'Roca',
  ghost: 'Fantasma', dragon: 'Dragón', normal: 'Normal', fairy: 'Hada'
};

const regions = ['Todas las regiones', 'Kanto', 'Kalos'];
---

<Layout title="Pokédex - Dashboard">
    
    <nav class="navbar glass">
        <div class="brand">
            <div class="pokeball-icon">
                <div class="pokeball-inner"></div>
            </div>
            <h1>Pokédex OS</h1>
        </div>
        <button id="logout-btn" class="btn-logout">Cerrar Sesión</button>
    </nav>

    <main class="main-container">
        
        <header class="hero-section">
            <h2 class="hero-title">Multiverso Pokémon</h2>
            <p class="hero-subtitle">Explora los Pokémon de las regiones de Kanto y Kalos.</p>
            
            <div class="filters-toolbar glass">
                <div class="search-group">
                    <div class="search-box">
                        <input 
                            type="text" 
                            id="search-input" 
                            placeholder="Nombre o ID..." 
                            autocomplete="off"
                        />
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="search-icon"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                    </div>
                </div>

                <div class="selectors-group">
                    <div class="select-wrapper">
                        <span class="select-label">Región</span>
                        <select id="region-selector">
                            {regions.map((r) => (
                                <option value={r === 'Todas las regiones' ? 'all' : r}>{r}</option>
                            ))}
                        </select>
                        <svg xmlns="http://www.w3.org/2000/svg" class="select-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
                    </div>

                    <div class="select-wrapper">
                        <span class="select-label">Tipo</span>
                        <select id="type-selector">
                            {Object.keys(typeTranslations).map((key) => (
                                <option value={key}>{typeTranslations[key]}</option>
                            ))}
                        </select>
                        <svg xmlns="http://www.w3.org/2000/svg" class="select-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
                    </div>
                </div>
            </div>
        </header>

        <div id="pokemon-grid" class="pokemon-grid">
            {pokemonData.map((pokemon: any) => (
                <PokemonCard 
                    id={pokemon.id} 
                    name={pokemon.name} 
                    types={pokemon.types} 
                    region={pokemon.region}
                />
            ))}
        </div>
        
        <div id="no-results" class="no-results hidden">
            <div class="no-results-content">
                <span class="error-emoji">🚫</span>
                <h3>No hay coincidencias</h3>
                <p>Prueba ajustando los filtros de búsqueda, región o tipo.</p>
            </div>
        </div>

    </main>
</Layout>

<script>
    function initApp() {
        const user = localStorage.getItem('pokeUser');
        if (!user) { window.location.href = '/'; return; }

        const logoutBtn = document.getElementById('logout-btn');
        if (logoutBtn) {
            logoutBtn.addEventListener('click', () => {
                localStorage.removeItem('pokeUser');
                window.location.href = '/';
            });
        }

        const searchInput = document.getElementById('search-input') as HTMLInputElement;
        const typeSelector = document.getElementById('type-selector') as HTMLSelectElement;
        const regionSelector = document.getElementById('region-selector') as HTMLSelectElement;
        const cards = document.querySelectorAll('.pokemon-card');
        const noResults = document.getElementById('no-results');

        function filterPokemon() {
            const searchTerm = searchInput.value.toLowerCase().trim();
            const selectedType = typeSelector.value;
            const selectedRegion = regionSelector.value;
            let hasResults = false;

            cards.forEach((card) => {
                const element = card as HTMLElement;
                const name = element.dataset.name || '';
                const id = element.dataset.id || '';
                const types = element.dataset.types || '';
                const region = element.dataset.region || '';

                const matchesName = name.includes(searchTerm) || id.includes(searchTerm);
                const matchesType = selectedType === 'all' || types.includes(selectedType);
                const matchesRegion = selectedRegion === 'all' || region === selectedRegion;

                if (matchesName && matchesType && matchesRegion) {
                    element.style.display = 'flex';
                    hasResults = true;
                } else {
                    element.style.display = 'none';
                }
            });

            if (noResults) {
                noResults.classList.toggle('hidden', hasResults);
            }
        }

        [searchInput, typeSelector, regionSelector].forEach(el => {
            if (el) el.addEventListener('input', filterPokemon);
            if (el instanceof HTMLSelectElement) el.addEventListener('change', filterPokemon);
        });
    }

    document.addEventListener('astro:page-load', initApp);
</script>

<style>
    .glass {
        background: rgba(255, 255, 255, 0.6);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.4);
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.05);
    }

    .navbar { 
        display: flex; 
        justify-content: space-between; 
        align-items: center; 
        padding: 0.75rem 2rem; 
        position: sticky; 
        top: 0; 
        z-index: 100; 
    }

    .brand { display: flex; align-items: center; gap: 0.75rem; }
    .brand h1 { font-size: 1.1rem; font-weight: 900; color: #1e293b; margin: 0; letter-spacing: -0.025em; }

    .pokeball-icon {
        width: 28px;
        height: 28px;
        background: #ef4444;
        border-radius: 50%;
        position: relative;
        overflow: hidden;
        border: 2px solid #1e293b;
    }
    .pokeball-icon::after {
        content: '';
        position: absolute;
        bottom: 0;
        width: 100%;
        height: 50%;
        background: white;
        border-top: 2px solid #1e293b;
    }
    .pokeball-inner {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 8px;
        height: 8px;
        background: white;
        border: 2px solid #1e293b;
        border-radius: 50%;
        z-index: 1;
    }

    .btn-logout { 
        background: transparent; 
        border: 1px solid rgba(239, 68, 68, 0.2); 
        color: #ef4444; 
        padding: 0.5rem 1.25rem; 
        border-radius: 12px; 
        cursor: pointer; 
        font-weight: 800; 
        font-size: 0.8rem;
        transition: all 0.2s; 
    }
    .btn-logout:hover { background: #ef4444; color: white; border-color: #ef4444; }
    
    .main-container { max-width: 1200px; margin: 0 auto; padding: 4rem 2rem; }

    .hero-section { text-align: center; margin-bottom: 5rem; }
    .hero-title { font-size: 3.5rem; font-weight: 900; color: #1e293b; margin-bottom: 0.75rem; letter-spacing: -0.06em; }
    .hero-subtitle { color: #64748b; font-size: 1.1rem; margin-bottom: 3.5rem; font-weight: 500; }

    /* FILTERS TOOLBAR */
    .filters-toolbar {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        max-width: 900px;
        margin: 0 auto;
        padding: 1.5rem;
        border-radius: 2rem;
    }

    @media (min-width: 768px) {
        .filters-toolbar {
            flex-direction: row;
            align-items: center;
            padding: 1rem 1.5rem;
        }
    }

    .search-group { flex: 2; }
    .search-box { position: relative; }
    .search-box input { 
        width: 100%; 
        padding: 0.85rem 1rem 0.85rem 3rem; 
        border: 1px solid rgba(0,0,0,0.08); 
        border-radius: 1.25rem; 
        font-size: 1rem; 
        outline: none; 
        transition: all 0.2s; 
        background: rgba(255, 255, 255, 0.7);
        font-weight: 500;
    }
    .search-box input:focus { border-color: #3b82f6; background: white; box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1); }
    .search-icon { position: absolute; left: 1.2rem; top: 50%; transform: translateY(-50%); color: #94a3b8; }

    .selectors-group { 
        display: flex; 
        gap: 1rem; 
        flex: 3;
    }

    .select-wrapper { 
        position: relative; 
        flex: 1; 
        display: flex;
        flex-direction: column;
        text-align: left;
    }

    .select-label {
        font-size: 0.65rem;
        font-weight: 900;
        text-transform: uppercase;
        color: #94a3b8;
        margin-left: 0.75rem;
        margin-bottom: 0.25rem;
        letter-spacing: 0.05em;
    }

    select {
        width: 100%;
        padding: 0.75rem 2.5rem 0.75rem 1rem;
        border: 1px solid rgba(0,0,0,0.08); 
        border-radius: 1.1rem;
        font-size: 0.95rem;
        background: rgba(255, 255, 255, 0.7);
        appearance: none;
        cursor: pointer;
        color: #1e293b;
        font-weight: 800;
        outline: none;
        transition: all 0.2s;
    }
    select:focus { border-color: #3b82f6; background: white; }
    .select-arrow { position: absolute; right: 1rem; bottom: 0.75rem; color: #94a3b8; pointer-events: none; }

    .pokemon-grid { 
        display: grid; 
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); 
        gap: 2.5rem; 
    }
    
    .hidden { display: none !important; }
    .no-results { 
        text-align: center; 
        padding: 6rem 2rem; 
        background: rgba(255, 255, 255, 0.3);
        border-radius: 3rem;
        margin-top: 2rem;
        border: 2px dashed rgba(0,0,0,0.05);
    }
    .error-emoji { font-size: 4rem; display: block; margin-bottom: 1.5rem; filter: grayscale(1); opacity: 0.5; }
    .no-results h3 { font-size: 1.75rem; color: #1e293b; margin-bottom: 0.75rem; font-weight: 900; }
    .no-results p { color: #64748b; font-size: 1.1rem; }

    @media (max-width: 640px) {
        .hero-title { font-size: 2.5rem; }
        .selectors-group { flex-direction: column; }
        .main-container { padding: 2rem 1.5rem; }
    }
</style>