---
import Layout from '../../layouts/Layout.astro';
import TypeBadge from '../../components/TypeBadge.astro';

import pokemonData from '../../data/pokemon.json';

export async function getStaticPaths() {
  return pokemonData.map((p: any) => {
    return { 
      params: { id: p.id.toString() } 
    };
  });
}

const { id } = Astro.params;

// 1. Fetch de datos básicos
const response = await fetch(`https://pokeapi.co/api/v2/pokemon/${id}`);
const pokemon = await response.json();

const name = pokemon.name;
const image = pokemon.sprites.other['official-artwork'].front_default;
const types = pokemon.types.map((t: any) => t.type.name);
const stats = pokemon.stats;

// 2. Fetch de Debilidades
const typeUrls = pokemon.types.map((t: any) => t.type.url);
const typeResponses = await Promise.all(typeUrls.map((url: string) => fetch(url)));
const typeData = await Promise.all(typeResponses.map((res) => res.json()));

let weaknessesSet = new Set<string>();
typeData.forEach((typeInfo: any) => {
    typeInfo.damage_relations.double_damage_from.forEach((weakness: any) => {
        weaknessesSet.add(weakness.name);
    });
});
const weaknesses = Array.from(weaknessesSet);

const statTranslations: any = {
  'hp': 'Salud', 'attack': 'Ataque', 'defense': 'Defensa',
  'special-attack': 'Atq. Esp.', 'special-defense': 'Def. Esp.', 'speed': 'Velocidad'
};
---

<Layout title={`Detalles de ${name}`}>
  <div class="detail-container">
    
    <nav class="detail-nav">
        <a href="/pokedex" class="back-btn glass">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
            Volver
        </a>
    </nav>

    <div class="poke-card glass main-card">
      <header class="card-header">
        <div class="title-group">
            <span class="pokemon-id">#{id.toString().padStart(3, '0')}</span>
            <h1 class="pokemon-name" transition:name={`pokemon-name-${id}`}>{name}</h1>
        </div>
      </header>

      <div class="card-body">
        
        <div class="visual-section">
          <div class="image-container">
             <img 
               src={image} 
               alt={name} 
               transition:name={`pokemon-img-${id}`}
             />
          </div>
          
          <div class="badges-group">
              <h3 class="section-title">Tipos</h3>
              <div class="types-container">
                {types.map((type: string) => <TypeBadge type={type} />)}
              </div>
          </div>

          <div class="badges-group">
             <h3 class="section-title">Debilidades</h3>
             <div class="types-container">
                {weaknesses.map((type: string) => (
                  <TypeBadge type={type} size="sm" />
                ))}
             </div>
          </div>
        </div>

        <div class="stats-section">
          <h3 class="stats-title">Estadísticas Base</h3>
          
          <div class="stats-grid">
            {stats.map((stat: any) => (
              <div class="stat-row">
                <div class="stat-label">
                  <span>{statTranslations[stat.stat.name] || stat.stat.name}</span>
                  <span class="stat-val">{stat.base_stat}</span>
                </div>
                
                <div class="progress-bg">
                  <div 
                    class="progress-fill" 
                    style={`width: ${(stat.base_stat / 200) * 100}%; background: ${stat.base_stat > 100 ? 'linear-gradient(90deg, #4ade80, #22c55e)' : stat.base_stat > 60 ? 'linear-gradient(90deg, #60a5fa, #3b82f6)' : 'linear-gradient(90deg, #f87171, #ef4444)'}`}
                  ></div>
                </div>
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>
  </div>
</Layout>

<style>
  .glass {
    background: rgba(255, 255, 255, 0.4);
    backdrop-filter: blur(15px);
    -webkit-backdrop-filter: blur(15px);
    border: 1px solid rgba(255, 255, 255, 0.4);
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
  }

  .detail-container {
    min-height: 100vh;
    padding: 2rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  .detail-nav {
      margin-bottom: 2rem;
  }

  .back-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: #1e293b;
    font-weight: 800;
    font-size: 0.9rem;
    padding: 0.75rem 1.25rem;
    border-radius: 1rem;
    transition: all 0.2s;
  }
  .back-btn:hover { transform: translateX(-5px); background: white; }

  .main-card {
    width: 100%;
    border-radius: 2.5rem;
    overflow: hidden;
    animation: slideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  @keyframes slideUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .card-header {
    background: rgba(255, 255, 255, 0.2);
    padding: 3rem 3rem 1rem;
  }

  .title-group { display: flex; flex-direction: column; align-items: center; text-align: center; }
  .pokemon-id { font-size: 1.5rem; font-weight: 900; color: rgba(0,0,0,0.1); letter-spacing: 0.2rem; margin-bottom: 0.25rem; }
  .pokemon-name { text-transform: capitalize; font-size: 3.5rem; margin: 0; color: #1e293b; font-weight: 900; letter-spacing: -0.05em; }

  .card-body {
    display: flex;
    flex-direction: column;
    padding: 0 3rem 4rem;
    gap: 4rem;
  }

  @media (min-width: 850px) {
    .card-body { flex-direction: row; align-items: center; }
    .visual-section { width: 45%; }
    .stats-section { width: 55%; }
    .title-group { align-items: flex-start; text-align: left; }
  }

  .visual-section {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  .image-container {
    width: 100%;
    max-width: 350px;
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .image-container::before {
      content: '';
      position: absolute;
      width: 80%;
      height: 80%;
      background: radial-gradient(circle, rgba(59, 130, 246, 0.1) 0%, transparent 70%);
      z-index: 0;
  }

  .image-container img {
    width: 90%;
    height: 90%;
    object-fit: contain;
    filter: drop-shadow(0 20px 30px rgba(0,0,0,0.15));
    z-index: 1;
    transition: transform 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }
  .image-container:hover img { transform: scale(1.05) rotate(2deg); }

  .badges-group { width: 100%; text-align: center; }

  .section-title {
      font-size: 0.75rem;
      text-transform: uppercase;
      color: #94a3b8;
      font-weight: 800;
      letter-spacing: 0.1rem;
      margin-bottom: 1rem;
  }

  .types-container {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  /* Sección Stats */
  .stats-section {
      background: rgba(255, 255, 255, 0.3);
      padding: 2.5rem;
      border-radius: 2rem;
      border: 1px solid rgba(255, 255, 255, 0.5);
  }
  .stats-title {
    font-size: 1.25rem;
    color: #1e293b;
    margin-bottom: 2rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.025em;
    margin-top: 0;
  }

  .stat-row { margin-bottom: 1.5rem; }
  .stat-label { display: flex; justify-content: space-between; margin-bottom: 0.5rem; font-size: 0.85rem; font-weight: 800; color: #64748b; text-transform: uppercase; }
  .stat-val { color: #1e293b; font-weight: 900; font-size: 1rem; }
  .progress-bg { background: rgba(0,0,0,0.05); height: 12px; border-radius: 6px; overflow: hidden; }
  .progress-fill { height: 100%; border-radius: 6px; transition: width 1s cubic-bezier(0.34, 1.56, 0.64, 1); }

  @media (max-width: 640px) {
      .pokemon-name { font-size: 2.5rem; }
      .card-body { padding: 0 1.5rem 3rem; }
      .card-header { padding: 2rem 1.5rem 0; }
  }
</style>