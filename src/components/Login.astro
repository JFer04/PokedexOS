---
// Parte del Servidor
---

<div class="login-wrapper">
  <div class="login-card glass">
    <div class="brand-icon">
      <div class="pokeball-container">
          <div class="pokeball">
              <div class="pokeball-button"></div>
          </div>
      </div>
    </div>

    <h2 class="title">Entrenador Pokémon</h2>
    <p class="subtitle">Accede a las bases de datos de Kanto y Kalos</p>

    <form id="login-form" class="login-form">
      <div class="input-group">
        <label for="username">Usuario</label>
        <div class="input-wrapper">
            <input
              type="text"
              id="username"
              placeholder="Ej: Ash Ketchum"
              required
            />
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="input-icon"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
        </div>
      </div>

      <div class="input-group">
        <label for="password">Contraseña</label>
        <div class="input-wrapper">
            <input type="password" id="password" placeholder="••••" required />
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="input-icon"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
        </div>
      </div>

      <button type="submit" class="btn-login"> 
          Ingresar al Sistema
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
      </button>

      <p id="error-msg" class="error-msg hidden">⚠ Credenciales incorrectas</p>
    </form>
    
    <div class="login-footer">
        <p>Tip: La contraseña es <code>1234</code></p>
    </div>
  </div>
</div>

<script>
  function initLogin() {
      const form = document.getElementById("login-form") as HTMLFormElement;
      const errorMsg = document.getElementById("error-msg") as HTMLParagraphElement;
      const usernameInput = document.getElementById("username") as HTMLInputElement;
      const passwordInput = document.getElementById("password") as HTMLInputElement;

      const user = localStorage.getItem("pokeUser");
      if (user) {
        window.location.href = "/pokedex";
      }

      if (form) {
        form.addEventListener("submit", (e) => {
          e.preventDefault();
          const username = usernameInput?.value;
          const password = passwordInput?.value;

          if (username && password === "1234") {
            localStorage.setItem("pokeUser", username);
            window.location.href = "/pokedex";
          } else {
            if (errorMsg) errorMsg.classList.remove("hidden");
            const card = document.querySelector(".login-card");
            card?.classList.add("shake");
            setTimeout(() => card?.classList.remove("shake"), 500);
          }
        });
      }
  }

  document.addEventListener("astro:page-load", initLogin);
</script>

<style>
  .login-wrapper {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
  }

  .glass {
    background: rgba(255, 255, 255, 0.4);
    backdrop-filter: blur(15px);
    -webkit-backdrop-filter: blur(15px);
    border: 1px solid rgba(255, 255, 255, 0.5);
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
  }

  .login-card {
    padding: 3rem;
    border-radius: 2rem;
    width: 100%;
    max-width: 420px;
    text-align: center;
    animation: fadeIn 0.8s ease-out;
  }

  @keyframes fadeIn {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
  }

  .pokeball-container {
      display: flex;
      justify-content: center;
      margin-bottom: 1.5rem;
  }

  .pokeball {
      width: 60px;
      height: 60px;
      background: #ef4444;
      border-radius: 50%;
      position: relative;
      overflow: hidden;
      border: 4px solid #1e293b;
      box-shadow: 0 5px 15px rgba(0,0,0,0.2);
  }
  .pokeball::after {
      content: '';
      position: absolute;
      bottom: 0;
      width: 100%;
      height: 50%;
      background: white;
      border-top: 4px solid #1e293b;
  }
  .pokeball-button {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 14px;
      height: 14px;
      background: white;
      border: 4px solid #1e293b;
      border-radius: 50%;
      z-index: 1;
  }

  .title {
    font-size: 2rem;
    font-weight: 900;
    color: #1e293b;
    margin: 0;
    letter-spacing: -0.05em;
  }

  .subtitle {
    color: #64748b;
    font-size: 1rem;
    margin-top: 0.5rem;
    margin-bottom: 2.5rem;
    font-weight: 500;
  }

  .login-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .input-group {
    text-align: left;
  }

  .input-group label {
    display: block;
    font-size: 0.85rem;
    font-weight: 800;
    color: #475569;
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .input-wrapper {
      position: relative;
  }

  .input-icon {
      position: absolute;
      left: 1rem;
      top: 50%;
      transform: translateY(-50%);
      color: #94a3b8;
  }

  .input-group input {
    width: 100%;
    padding: 0.85rem 1rem 0.85rem 2.8rem;
    border: 1px solid rgba(0,0,0,0.1);
    border-radius: 1rem;
    font-size: 1rem;
    outline: none;
    transition: all 0.2s;
    background: rgba(255, 255, 255, 0.6);
    color: #1e293b;
    box-sizing: border-box;
  }

  .input-group input:focus {
    border-color: #3b82f6;
    background: white;
    box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1);
  }

  .btn-login {
    margin-top: 1rem;
    background: #1e293b;
    color: white;
    padding: 1rem;
    border: none;
    border-radius: 1.25rem;
    font-size: 1rem;
    font-weight: 800;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .btn-login:hover {
    background: #0f172a;
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.1);
  }

  .btn-login:active {
    transform: scale(0.98);
  }

  .error-msg {
    color: #ef4444;
    font-size: 0.85rem;
    margin-top: 0.5rem;
    font-weight: 700;
    background: rgba(239, 68, 68, 0.1);
    padding: 0.75rem;
    border-radius: 0.75rem;
  }

  .login-footer {
      margin-top: 2rem;
      font-size: 0.8rem;
      color: #94a3b8;
  }
  .login-footer code {
      background: rgba(0,0,0,0.05);
      padding: 0.2rem 0.4rem;
      border-radius: 0.4rem;
      font-weight: 700;
      color: #64748b;
  }

  .hidden { display: none; }

  .shake {
    animation: shake 0.5s cubic-bezier(0.36, 0.07, 0.19, 0.97) both;
  }

  @keyframes shake {
    10%, 90% { transform: translate3d(-1px, 0, 0); }
    20%, 80% { transform: translate3d(2px, 0, 0); }
    30%, 50%, 70% { transform: translate3d(-4px, 0, 0); }
    40%, 60% { transform: translate3d(4px, 0, 0); }
  }
</style>
